# =============================================
# ROUTEIT - Variables de entorno (EJEMPLO)
# Copiar a .env y completar con valores reales
# NUNCA commitear el archivo .env
# =============================================

# PostgreSQL
POSTGRES_USER=routeit
POSTGRES_PASSWORD=change_me
POSTGRES_DB=routeit

# JWT
JWT_SECRET=change_me_with_a_256bit_random_string_minimum

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me

# Google Maps Platform
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenWeatherMap
OPENWEATHERMAP_API_KEY=your_openweathermap_key_here

# Mercado Pago (sandbox)
MP_ACCESS_TOKEN=your_mp_access_token_sandbox
MP_PUBLIC_KEY=your_mp_public_key_sandbox

# SMTP (para envío de mails de verificación)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# Frontend URL (para links en emails)
FRONTEND_URL=http://localhost:4200
